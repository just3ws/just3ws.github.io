#!/usr/bin/env sh
set -e

source .env

bundle exec jekyll clean --verbose --trace

if command -v open >/dev/null 2>&1; then
  if [ -d "/Applications/Google Chrome.app" ] || [ -d "$HOME/Applications/Google Chrome.app" ]; then
    bundle exec jekyll serve --verbose --watch --livereload --trace --host 127.0.0.1 --port 4000 &
    JEKYLL_PID=$!
    sleep 2
    open -a "Google Chrome" "http://127.0.0.1:4000/"
    wait "$JEKYLL_PID"
  else
    bundle exec jekyll serve --verbose --watch --livereload --open-url --trace --host 127.0.0.1 --port 4000
  fi
else
  bundle exec jekyll serve --verbose --watch --livereload --trace --host 127.0.0.1 --port 4000
fi
