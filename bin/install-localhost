#!/usr/bin/env bash
# bin/install-localhost — serve this site persistently at https://just3ws.localhost
#
# Installs the project-owned nginx vhost (nginx/just3ws.localhost.conf) into the
# Homebrew nginx servers/ dir, mirroring how my.localhost / zdots.localhost are
# deployed. nginx serves the static _site/ build, so the site is up whenever
# nginx is — no dev server required.
#
# Two steps still need YOUR system access (keychain / sudo); this script prints
# the exact commands rather than running privileged operations for you:
#   1. Add just3ws.localhost to the shared TLS cert SAN list (mkcert).
#   2. Reload nginx.
set -euo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"
VHOST_SRC="$REPO/nginx/just3ws.localhost.conf"
NGINX_PREFIX="/opt/homebrew/etc/nginx"
VHOST_DST="$NGINX_PREFIX/servers/just3ws.conf"
CERT="$NGINX_PREFIX/certs/zdots-local.pem"
KEY="$NGINX_PREFIX/certs/zdots-local-key.pem"

info() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*"; }

[ -f "$VHOST_SRC" ] || { echo "missing $VHOST_SRC"; exit 1; }
[ -d "$NGINX_PREFIX/servers" ] || { echo "nginx not set up at $NGINX_PREFIX — run zdots bootstrap first"; exit 1; }

info "Installing vhost → $VHOST_DST"
cp "$VHOST_SRC" "$VHOST_DST"

# Build the site if _site/ is missing so nginx has something to serve.
if [ ! -d "$REPO/_site" ]; then
  info "Building site (_site/ missing)…"
  ( cd "$REPO" && bundle exec jekyll build )
fi

# Does the shared cert already cover just3ws.localhost?
cert_has_host=false
if [ -f "$CERT" ] && openssl x509 -in "$CERT" -noout -ext subjectAltName 2>/dev/null | grep -q "just3ws.localhost"; then
  cert_has_host=true
fi

echo
if [ "$cert_has_host" = true ]; then
  info "TLS cert already covers just3ws.localhost ✓"
else
  warn "TLS cert does NOT yet cover just3ws.localhost. Regenerate it (keychain prompt):"
  cat <<EOF

  mkcert -cert-file "$CERT" \\
         -key-file  "$KEY" \\
         llama.localhost embed.localhost o2.localhost zdots.localhost \\
         my.localhost my.local dev.my.local zdots.local \\
         just3ws.localhost localhost 127.0.0.1

  (Persistent: also add just3ws.localhost to the mkcert SAN list in
   ~/.config/zsh/bin/bootstrap so a future cert regen keeps it.)
EOF
fi

echo
info "Then validate + reload nginx (sudo):"
cat <<'EOF'

  nginx -t
  sudo launchctl kickstart -k system/homebrew.mxcl.nginx

  # (Do NOT use `sudo brew services restart nginx` — it takes root ownership
  #  of Homebrew paths. Kickstart is the zdots-blessed restart.)
EOF

echo
info "Then browse: https://just3ws.localhost"
info "Refresh content with: bundle exec jekyll build   (nginx serves _site/)"
